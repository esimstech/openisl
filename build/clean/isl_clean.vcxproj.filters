      <Filter>Source Files</Filter>
    </CustomBuild>
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="..\..\code\api\isl_api\include\swversion.h">
      <Filter>Header Files</Filter>
    </ClInclude>
  </ItemGroup>
  <ItemGroup>
    <ClCompile Include="..\..\code\api\isl_api_cli\src\AssemblyInfo.cpp">
      <Filter>Source Files</Filter>
    </ClCompile>
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\code\api\isl_api_python\src\setup.py" />
    <None Include="..\..\code\api\isl_api_python\project\01_install.bat">
      <Filter>Source Files</Filter>
    </None>
  </ItemGroup>
</Project>